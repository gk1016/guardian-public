# ──────────────────────────────────────────────────────────────
# Guardian Flight — Environment Configuration
# Copy this file to .env and edit the values below.
# ──────────────────────────────────────────────────────────────

# Database connection string. The password here must match POSTGRES_PASSWORD below.
# Only change the password portion — leave the rest as-is unless you know what you're doing.
DATABASE_URL=postgresql://guardian:CHANGE_ME@guardian-postgres:5432/guardian

# PostgreSQL credentials. These are used to initialize the database container.
# If you change POSTGRES_PASSWORD, you MUST also update the password in DATABASE_URL above.
# Generate a strong password: openssl rand -hex 32
POSTGRES_USER=guardian
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=guardian

# Next.js port (internal to Docker — you don't need to change this)
PORT=3000

# Environment mode (leave as production for Docker deployments)
NODE_ENV=production

# Secret key used to sign login tokens (JWTs).
# Generate a strong secret: openssl rand -hex 32
AUTH_SECRET=CHANGE_ME

# Password for the three demo accounts created by the seed script.
# Accounts: reaper11@guardian.local, saber1@guardian.local, viking2@guardian.local
GUARDIAN_DEMO_PASSWORD=GuardianDemo!2026

# The hostname or IP address Caddy uses for TLS certificate generation.
# - "localhost" generates a self-signed cert (default, good for local testing)
# - "192.168.1.50" generates a self-signed cert for that LAN IP
# - "guardian.example.com" with tls internal removed from Caddyfile will auto-provision Let's Encrypt
SITE_ADDRESS=localhost

# The port Caddy listens on for HTTPS. Mapped to the host machine.
# Change this if port 443 is already in use on your machine.
HTTPS_PORT=443

# ──────────────────────────────────────────────────────────────
# Backup Configuration
# ──────────────────────────────────────────────────────────────

# How often to run pg_dump (in hours). Default: every 24 hours.
BACKUP_INTERVAL_HOURS=24

# How many days of backups to keep before pruning. Default: 7 days.
BACKUP_RETENTION_DAYS=7
