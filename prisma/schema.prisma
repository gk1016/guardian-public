generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  handle       String        @unique
  displayName  String?
  passwordHash String?
  role         String        @default("pilot")
  status       String        @default("pending")
  totpSecret   String?
  totpEnabled  Boolean       @default(false)
  sessionsInvalidatedAt DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  memberships  OrgMember[]
  ledMissions  Mission[]     @relation("mission_lead")
  missionLogs  MissionLog[]  @relation("mission_log_author")
  rescueOwned  RescueRequest[] @relation("rescue_requester")
  rescueOps    RescueRequest[] @relation("rescue_operator")
  qrfDispatches QrfDispatch[] @relation("qrf_dispatch_author")
  incidentsReported Incident[] @relation("incident_reporter")
  incidentsReviewed Incident[] @relation("incident_reviewer")
  notificationsCreated Notification[] @relation("notification_creator")
  manualEntries ManualEntry[] @relation("manual_author")
  auditLogs    AuditLog[]
}

model Organization {
  id          String      @id @default(cuid())
  name        String
  tag         String      @unique
  description String?
  isPublic    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  members     OrgMember[]
  doctrineTemplates DoctrineTemplate[]
  missions    Mission[]
  intel       IntelReport[]
  rescues     RescueRequest[]
  qrfReadiness QrfReadiness[]
  qrfDispatches QrfDispatch[]
  incidents   Incident[]
  notifications Notification[]
  alertRules  AlertRule[]
  manualEntries ManualEntry[]
  aiConfigs   AiConfig[]
  aiAnalyses  AiAnalysis[]
  auditLogs   AuditLog[]
}

model OrgMember {
  id         String       @id @default(cuid())
  userId     String
  orgId      String
  rank       String       @default("member")
  title      String?
  joinedAt   DateTime     @default(now())
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
}

model Mission {
  id              String               @id @default(cuid())
  orgId           String
  doctrineTemplateId String?
  callsign        String
  title           String
  missionType     String
  status          String               @default("planning")
  priority        String               @default("routine")
  revisionNumber  Int                  @default(1)
  areaOfOperation String?
  missionBrief    String?
  closeoutSummary String?
  aarSummary      String?
  mettTc          Json?
  phases          Json?
  roeCode         String?
  leadId          String?
  startsAt        DateTime?
  completedAt     DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  org             Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  doctrineTemplate DoctrineTemplate?   @relation(fields: [doctrineTemplateId], references: [id], onDelete: SetNull)
  lead            User?                @relation("mission_lead", fields: [leadId], references: [id], onDelete: SetNull)
  intelLinks      MissionIntelLink[]
  logs            MissionLog[]
  participants    MissionParticipant[]
  qrfDispatches   QrfDispatch[]
  incidents       Incident[]

  @@index([orgId, status])
  @@index([doctrineTemplateId])
  @@index([missionType])
}

model DoctrineTemplate {
  id         String       @id @default(cuid())
  orgId      String
  code       String
  title      String
  category   String
  summary    String
  body       String
  escalation String?
  isDefault  Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  missions   Mission[]

  @@unique([orgId, code])
  @@index([orgId, category])
}

model MissionLog {
  id        String   @id @default(cuid())
  missionId String
  authorId  String?
  entryType String   @default("status")
  message   String
  createdAt DateTime @default(now())
  author    User?    @relation("mission_log_author", fields: [authorId], references: [id], onDelete: SetNull)
  mission   Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId, createdAt])
  @@index([entryType])
}

model MissionIntelLink {
  id        String      @id @default(cuid())
  missionId String
  intelId   String
  createdAt DateTime    @default(now())
  mission   Mission     @relation(fields: [missionId], references: [id], onDelete: Cascade)
  intel     IntelReport @relation(fields: [intelId], references: [id], onDelete: Cascade)

  @@unique([missionId, intelId])
  @@index([missionId])
  @@index([intelId])
}

model MissionParticipant {
  id         String   @id @default(cuid())
  missionId  String
  handle     String
  role       String
  platform   String?
  status     String   @default("assigned")
  notes      String?
  createdAt  DateTime @default(now())
  mission    Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
}

model IntelReport {
  id             String       @id @default(cuid())
  orgId          String
  reportType     String       @default("sighting")
  title          String
  description    String?
  severity       Int          @default(3)
  locationName   String?
  starSystem     String?
  hostileGroup   String?
  confidence     String       @default("medium")
  isActive       Boolean      @default(true)
  isVerified     Boolean      @default(false)
  tags           String[]
  observedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  missionLinks   MissionIntelLink[]
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, isActive])
  @@index([severity])
}

model RescueRequest {
  id                String       @id @default(cuid())
  orgId             String
  requesterId       String
  operatorId        String?
  survivorHandle    String
  locationName      String?
  status            String       @default("open")
  urgency           String       @default("routine")
  threatSummary     String?
  rescueNotes       String?
  survivorCondition String?
  outcomeSummary    String?
  escortRequired    Boolean      @default(false)
  medicalRequired   Boolean      @default(false)
  offeredPayment    Int?
  roeCode           String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  org               Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  requester         User         @relation("rescue_requester", fields: [requesterId], references: [id], onDelete: Cascade)
  operator          User?        @relation("rescue_operator", fields: [operatorId], references: [id], onDelete: SetNull)
  dispatches        QrfDispatch[]
  incidents         Incident[]

  @@index([orgId, status])
  @@index([urgency])
}

model QrfReadiness {
  id            String       @id @default(cuid())
  callsign      String
  orgId         String
  status        String       @default("redcon4")
  platform      String?
  locationName  String?
  availableCrew Int          @default(1)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  dispatches    QrfDispatch[]

  @@index([orgId, status])
}

model QrfDispatch {
  id             String        @id @default(cuid())
  orgId          String
  qrfId          String
  missionId      String?
  rescueId       String?
  dispatchedById String
  status         String        @default("tasked")
  notes          String?
  dispatchedAt   DateTime      @default(now())
  arrivedAt      DateTime?
  rtbAt          DateTime?
  updatedAt      DateTime      @updatedAt
  org            Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  qrf            QrfReadiness  @relation(fields: [qrfId], references: [id], onDelete: Cascade)
  mission        Mission?      @relation(fields: [missionId], references: [id], onDelete: SetNull)
  rescue         RescueRequest? @relation(fields: [rescueId], references: [id], onDelete: SetNull)
  dispatchedBy   User          @relation("qrf_dispatch_author", fields: [dispatchedById], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([qrfId, dispatchedAt])
  @@index([missionId])
  @@index([rescueId])
}

model Incident {
  id             String        @id @default(cuid())
  orgId          String
  missionId      String?
  rescueId       String?
  reporterId     String
  reviewerId     String?
  title          String
  category       String        @default("contact")
  severity       Int           @default(3)
  status         String        @default("open")
  summary        String
  lessonsLearned String?
  actionItems    String?
  publicSummary  String?
  closedAt       DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  org            Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  mission        Mission?      @relation(fields: [missionId], references: [id], onDelete: SetNull)
  rescue         RescueRequest? @relation(fields: [rescueId], references: [id], onDelete: SetNull)
  reporter       User          @relation("incident_reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer       User?         @relation("incident_reviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([missionId])
  @@index([rescueId])
  @@index([severity])
}

model Notification {
  id             String       @id @default(cuid())
  orgId          String
  createdById    String?
  category       String       @default("ops")
  severity       String       @default("info")
  title          String
  body           String
  href           String?
  status         String       @default("unread")
  acknowledgedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy      User?        @relation("notification_creator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([orgId, status, createdAt])
  @@index([severity])
}

model AlertRule {
  id              String       @id @default(cuid())
  orgId           String
  name            String
  metric          String
  operator        String
  threshold       Float
  severity        String       @default("warning")
  isEnabled       Boolean      @default(true)
  cooldownMinutes Int          @default(60)
  lastTriggeredAt DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, isEnabled])
}

model ManualEntry {
  id           String       @id @default(cuid())
  orgId        String
  authorId     String
  title        String
  category     String       @default("general")
  body         String       @default("")
  entryType    String       @default("article")
  fileName     String?
  fileSize     Int?
  fileMimeType String?
  fileData     Bytes?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  author       User         @relation("manual_author", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([orgId, category])
}

model AiConfig {
  id               String       @id @default(cuid())
  orgId            String
  provider         String       @default("anthropic")
  model            String       @default("claude-sonnet-4-20250514")
  apiKey           String?
  baseUrl          String?
  maxTokens        Int          @default(2048)
  temperature      Float        @default(0.3)
  enabled          Boolean      @default(false)
  tickIntervalSecs Int          @default(300)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model AiAnalysis {
  id            String       @id @default(cuid())
  orgId         String
  analysisType  String
  targetId      String?
  summary       String
  provider      String
  model         String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, analysisType, createdAt])
  @@index([targetId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  orgId      String?
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  org        Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([userId, createdAt])
  @@index([targetType, targetId])
}
