{$SITE_ADDRESS:localhost} {
    {$TLS_DIRECTIVE:tls internal}

    @options method OPTIONS
    respond @options 204

    # WebSocket — dedicated route, direct proxy, no prefix stripping
    handle /ws {
        reverse_proxy {$UPSTREAM_ENGINE:guardian-engine:3420}
    }

    # Engine internal routes (non-WS)
    handle /engine/* {
        uri strip_prefix /engine
        reverse_proxy {$UPSTREAM_ENGINE:guardian-engine:3420}
    }

    # Everything else → Next.js frontend (with full security headers)
    handle {
        header {
            Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' wss: ws:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
            X-Frame-Options "DENY"
            X-Content-Type-Options "nosniff"
            Referrer-Policy "strict-origin-when-cross-origin"
            Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
            Strict-Transport-Security "max-age=31536000; includeSubDomains"
            Access-Control-Allow-Origin "{$SITE_ADDRESS:https://localhost}"
            Access-Control-Allow-Methods "GET, POST, PATCH, DELETE, OPTIONS"
            Access-Control-Allow-Headers "Content-Type, Authorization"
            Access-Control-Max-Age "86400"
            -Server
        }
        reverse_proxy {$UPSTREAM_GUARDIAN:guardian:3000}
    }
}
